#!/usr/bin/env bash

# Usage: GetPartWithParent <part_name> <part_version_name> <parent_name> <parent_version_name>

source ~/bin/sqlite/common

PART_NAME="${1:-}"
PART_VER_NAME="${2:-}"
PARENT_NAME="${3:-}"
PARENT_VER_NAME="${4:-}"

if [[ -z "$PART_NAME" || -z "$PART_VER_NAME" || -z "$PARENT_NAME" || -z "$PARENT_VER_NAME" ]]; then
 echo ""
 exit 0
fi

# Resolve IDs using existing Get* scripts
part_name_id=$(~/bin/sqlite/GetSentence "$PART_NAME")
part_version_id=$(~/bin/sqlite/GetVersionName "$PART_VER_NAME")
parent_name_id=$(~/bin/sqlite/GetSentence "$PARENT_NAME")
parent_version_id=$(~/bin/sqlite/GetVersionName "$PARENT_VER_NAME")

if [[ -z "$part_name_id" || -z "$part_version_id" || -z "$parent_name_id" || -z "$parent_version_id" ]]; then
 echo ""
 exit 0
fi

# Find the "lowest" (smallest parent id) existing parent part with this name/version
parent_id=$(sqlite_query_one "
 SELECT id
 FROM Part
 WHERE name = $parent_name_id
  AND version = $parent_version_id
  AND serial IS NULL
 ORDER BY parent ASC
 LIMIT 1;
")

# If not found, create it (this calls your existing GetPart with version)
if [[ -z "$parent_id" ]]; then
 parent_id=$(~/bin/sqlite/GetPart "$PARENT_NAME" "$PARENT_VER_NAME")
 if [[ -z "$parent_id" ]]; then
  echo ""
  exit 0
 fi
fi

# Now look for the child part with this parent
part_id=$(sqlite_query_one "
 SELECT id
 FROM Part
 WHERE parent = $parent_id
  AND name = $part_name_id
  AND version = $part_version_id
  AND serial IS NULL
 LIMIT 1;
")

if [[ -n "$part_id" ]]; then
 echo "$part_id"
 exit 0
fi

# Insert the child part if missing
insert_result=$(sqlite_run "
 INSERT OR IGNORE INTO Part (parent, name, version)
 VALUES ($parent_id, $part_name_id, $part_version_id);
")

# Fetch the id (now guaranteed to exist if parent was valid)
part_id=$(sqlite_query_one "
 SELECT id
 FROM Part
 WHERE parent = $parent_id
  AND name = $part_name_id
  AND version = $part_version_id
  AND serial IS NULL
 LIMIT 1;
")

echo "${part_id:-}"
